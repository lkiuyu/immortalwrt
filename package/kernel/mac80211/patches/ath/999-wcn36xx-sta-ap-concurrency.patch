+static const struct ieee80211_iface_limit wcn36xx_iface_limits[] = {
+	{
+		.max = 1,
+		.types = BIT(NL80211_IFTYPE_STATION),
+	},
+	{
+		.max = 1,
+		.types = BIT(NL80211_IFTYPE_AP),
+	},
+};
+
+static const struct ieee80211_iface_combination wcn36xx_iface_combinations[] = {
+	{
+		.limits = wcn36xx_iface_limits,
+		.n_limits = ARRAY_SIZE(wcn36xx_iface_limits),
+		.max_interfaces = 2,
+		.num_different_channels = 1,
+	},
+};
+
 static inline u8 get_sta_index(struct ieee80211_vif *vif,
 			       struct wcn36xx_sta *sta_priv)
 {
 	return NL80211_IFTYPE_STATION == vif->type ?
@@ -1435,8 +1455,13 @@ static int wcn36xx_init_ieee80211(struct wcn36xx *wcn)
