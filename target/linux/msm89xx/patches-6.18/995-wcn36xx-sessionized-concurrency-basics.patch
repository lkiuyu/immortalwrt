+static u32 wcn36xx_count_active_sessions(struct wcn36xx *wcn)
+{
+	struct wcn36xx_vif *tmp;
+	u32 count = 0;
+
+	list_for_each_entry(tmp, &wcn->vif_list, list) {
+		if (tmp->bss_index != WCN36XX_HAL_BSS_INVALID_IDX ||
+		    tmp->self_sta_index != WCN36XX_HAL_STA_INVALID_IDX)
+			count++;
+	}
+
+	return count ? count : 1;
+}
